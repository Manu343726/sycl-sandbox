{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build release",
            "type": "shell",
            "command": "cmake --preset conan-release -B build && make -C build -j$(nproc)",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build debug",
            "type": "shell",
            "command": "cmake --preset conan-debug -B build_debug && make -C build_debug -j$(nproc)",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build tracy-server",
            "type": "shell",
            "command": "cmake --build build --target tracy-server",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "launch tracy-server",
            "type": "shell",
            "command": "cmake --build build --target tracy-server && ${workspaceFolder}/build/profiler/bin/bin/tracy-profiler",
            "group": "none",
            "problemMatcher": ["$gcc"]
        }
    ]
}
